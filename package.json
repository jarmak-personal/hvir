{
  "name": "hvir",
  "version": "0.0.0",
  "description": "A lightweight, view-first workbench for agentic development.",
  "author": "hvir",
  "license": "MIT",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "npm run install:runtime",
    "install:runtime": "install-electron --no && electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:dir": "npm run build && electron-builder --dir",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-seams": "bash scripts/check-seams.sh",
    "verify": "npm run check-seams && npm run lint && npm run typecheck && npm test",
    "smoke": "electron-vite build && cross-env HVIR_SMOKE=1 electron . --no-sandbox",
    "smoke:capacity": "electron-vite build && cross-env HVIR_SMOKE=1 HVIR_CAPACITY_SMOKE=1 electron . --no-sandbox",
    "gauntlet": "bash scripts/phase8-gauntlet.sh"
  },
  "dependencies": {
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "chokidar": "^5.0.0",
    "ghostty-web": "^0.4.0",
    "markdown-it": "^14.3.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "node-pty": "^1.1.0",
    "shiki": "^4.3.1",
    "ssh-config": "^5.2.0",
    "ssh2": "^1.17.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "prettier": "^3.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.0"
  }
}
