{
  "name": "hvir",
  "version": "0.1.5",
  "description": "A lightweight, view-first workbench for agentic development.",
  "author": {
    "name": "hvir contributors",
    "email": "jarmak-personal@users.noreply.github.com"
  },
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://github.com/jarmak-personal/hvir",
  "repository": {
    "type": "git",
    "url": "https://github.com/jarmak-personal/hvir.git"
  },
  "bugs": "https://github.com/jarmak-personal/hvir/issues",
  "desktopName": "hvir",
  "keywords": [
    "agentic-development",
    "electron",
    "terminal",
    "git",
    "ssh"
  ],
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "npm run install:runtime && patch-package",
    "install:runtime": "install-electron --no && electron-rebuild -f -o node-pty",
    "predev": "node scripts/check-terminal-runtime-patch.mts",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:dir": "npm run build && electron-builder --dir",
    "pack:npm:launcher": "node scripts/package-npm.mjs launcher",
    "pack:npm:linux:x64": "npm run build && electron-builder --linux --x64 --dir --publish never && node scripts/package-npm.mjs platform linux x64 dist",
    "pack:npm:linux:arm64": "npm run build && electron-builder --linux --arm64 --dir --publish never && node scripts/package-npm.mjs platform linux arm64 dist",
    "pack:npm:mac:arm64": "npm run build && electron-builder --mac --arm64 --dir --publish never && node scripts/package-npm.mjs platform darwin arm64 dist",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-seams": "bash scripts/check-seams.sh",
    "check-adrs": "node scripts/check-adrs.mjs",
    "architecture:report": "node scripts/architecture-hotspots.mjs",
    "architecture:check": "node scripts/architecture-hotspots.mjs --enforce",
    "spike:pty-broker:evaluate": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/pty-broker-spike/evaluate.ts",
    "spike:pty-broker:real": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/pty-broker-spike/real-harness-trial.ts",
    "project:kind": "node scripts/project-management/sync-kind.ts",
    "project:record": "node scripts/project-management/read-planning-record.ts",
    "project:pr": "node scripts/project-management/sync-pull-request-planning.ts",
    "issue:context": "node scripts/project-management/read-issue-context.ts",
    "verify": "npm run check-seams && npm run check-adrs && npm run architecture:check && npm run lint && npm run typecheck && npm test && node npm/launcher/hvir.mjs --help",
    "smoke": "electron-vite build && node scripts/run-smoke-scenarios.mts",
    "smoke:macos": "electron-vite build && node scripts/run-smoke-scenarios.mts pty-native viewer-position platform-contracts terminal-presentation capacity",
    "smoke:packaged": "bash scripts/run-packaged-smoke.sh",
    "smoke:capacity": "electron-vite build && cross-env HVIR_SMOKE_SCENARIO=capacity node scripts/run-smoke-scenarios.mts",
    "gauntlet": "bash scripts/phase8-gauntlet.sh"
  },
  "dependencies": {
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "chokidar": "^5.0.0",
    "ghostty-web": "^0.4.0",
    "markdown-it": "^14.3.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "node-pty": "^1.1.0",
    "shiki": "^4.3.1",
    "ssh-config": "^5.2.0",
    "ssh2": "^1.17.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.0.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "happy-dom": "^20.11.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.0"
  }
}
